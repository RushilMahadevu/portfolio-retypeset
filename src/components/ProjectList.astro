---
import type { CollectionEntry } from 'astro:content'
import PinIcon from '@/assets/icons/pin-icon.svg'
import PostDate from '@/components/PostDate.astro'
import { defaultLocale } from '@/config'

type Project = CollectionEntry<'projects'> & {
  remarkPluginFrontmatter: {
    minutes: number
  }
}

const { projects, lang, pinned = false, columns = 1 } = Astro.props
const isTwoCol = columns === 2

export interface Props {
  projects: Project[]
  lang: string
  pinned?: boolean
  columns?: 1 | 2
}

function getProjectPath(project: Project) {
  const slug = project.data.abbrlink || project.id

  if (lang === defaultLocale) {
    return `/projects/${slug}/`
  }

  return `/${lang}/projects/${slug}/`
}
---

<ul class:list={[
  isTwoCol ? 'grid grid-cols-2 gap-x-6 gap-y-10' : '',
]}
>
  {projects.map(project => (
    <li class:list={[
      isTwoCol ? '' : 'mb-10',
    ]}
    >
      {/* project title */}
      <h3 class="inline transition-colors hover:c-primary">
        <a
          class="inline-flex items-center gap-2.5 text-4.5 cjk:tracking-0.02em"
          href={getProjectPath(project)}
          transition:name={`project-${project.data.abbrlink || project.id}${lang ? `-${lang}` : ''}`}
          data-disable-theme-transition
        >
          {project.data.icon && <span class:list={[project.data.icon, 'w-1.1em h-1.1em inline-block shrink-0']} />}
          <span class="font-serif">{project.data.title}</span>
        </a>
        {/* pinned icon */}
        {pinned && (
          <PinIcon
            aria-hidden="true"
            class="ml-0.25em inline-block aspect-square w-0.98em translate-y--0.1em lg:(w-1.05em translate-y--0.15em)"
            fill="currentColor"
          />
        )}
      </h3>

      {/* project time + status */}
      <div
        class="py-0.8 text-3.5 font-time"
        transition:name={`time-${project.data.abbrlink || project.id}${lang ? `-${lang}` : ''}`}
        data-disable-theme-transition
      >
        <PostDate
          date={project.data.published}
          minutes={project.remarkPluginFrontmatter.minutes}
        />
        {project.data.status && (
          <span class="ml-2 inline-flex items-center gap-1 text-3">
            ·
            <span
              class:list={[
                'inline-block w-1.5 h-1.5 rounded-full',
                project.data.status === 'completed' ? 'bg-green-500' : 'bg-amber-400',
              ]}
            />
            {project.data.status.replace('-', ' ')}
          </span>
        )}
      </div>

      {/* Project image — always shown, big */}
      {project.data.image && (
        <a href={getProjectPath(project)} class="mb-3 mt-2 block overflow-hidden rounded-lg">
          <img
            src={project.data.image}
            alt={`${project.data.title} preview`}
            class:list={[
              'w-full object-cover transition-transform duration-300 hover:scale-102',
              isTwoCol ? 'aspect-[4/3]' : 'h-64 lg:h-[28rem]',
            ]}
            loading="lazy"
            decoding="async"
          />
        </a>
      )}

      {/* description — always shown */}
      {project.data.description && (
        <p class="mt-1 text-3.5 c-secondary">
          {project.data.description}
        </p>
      )}

      {/* links */}
      {(project.data.github || project.data.demo) && (
        <p class="mt-1.5 text-3.5">
          {project.data.github && (
            <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:c-primary">
              GitHub
            </a>
          )}
          {project.data.demo && (
            <>
              {project.data.github && <span class="mx-1">·</span>}
              <a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="transition-colors hover:c-primary">
                Demo
              </a>
            </>
          )}
        </p>
      )}
    </li>
  ))}
</ul>
