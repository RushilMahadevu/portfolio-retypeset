---
import PostList from '@/components/PostList.astro'
import ProjectList from '@/components/ProjectList.astro'
import { defaultLocale, moreLocales } from '@/config'
import Layout from '@/layouts/Layout.astro'
import { getPinnedPosts, getPostsByYear, getProjects } from '@/utils/content'

export async function getStaticPaths() {
  type PathItem = {
    params: { index: string | undefined }
    props: { lang: string }
  }

  const paths: PathItem[] = []

  paths.push({
    params: { index: undefined },
    props: { lang: defaultLocale },
  })

  moreLocales.forEach((lang: string) => {
    paths.push({
      params: { index: `${lang}/` },
      props: { lang },
    })
  })

  return paths
}

const { lang } = Astro.props

const allProjects = await getProjects(lang)
const pinnedPosts = await getPinnedPosts(lang)
const postsByYear = await getPostsByYear(lang)
---

<Layout>
  <!-- Projects Section -->
  <section class="mb-12">
    <h2 class="mb-6 text-3.5 c-secondary/60 font-semibold tracking-widest font-navbar uppercase">
      Projects
    </h2>
    <ProjectList projects={allProjects} lang={lang} columns={2} />
  </section>

  <!-- Writing Section -->
  <section>
    <h2 class="mb-6 text-3.5 c-secondary/60 font-semibold tracking-widest font-navbar uppercase">
      Writing
    </h2>

    {pinnedPosts.length > 0 && (
      <div class="mb-7.5">
        <div class="uno-decorative-line" />
        <PostList posts={pinnedPosts} lang={lang} pinned={true} />
      </div>
    )}

    {[...postsByYear.entries()].map(([_year, posts]) => (
      <div class="mb-7.5">
        <div class="uno-decorative-line" />
        <PostList posts={posts} lang={lang} />
      </div>
    ))}
  </section>
</Layout>
