---
import CombinedContentList from '@/components/CombinedContentList.astro'
import TagList from '@/components/TagList.astro'
import { defaultLocale, moreLocales } from '@/config'
import Layout from '@/layouts/Layout.astro'
import { getAllCombinedTags, getCombinedTagSupportedLangs, getContentByTag, getPosts, getProjects } from '@/utils/content'

export async function getStaticPaths() {
  type PathItem = {
    params: { tags_tag: string }
    props: { tag: string, lang: string }
  }

  const paths: PathItem[] = []

  // Default locale
  const defaultTags = await getAllCombinedTags(defaultLocale)
  defaultTags.forEach((tag: string) => {
    paths.push({
      params: { tags_tag: `tags/${tag}/` },
      props: { tag, lang: defaultLocale },
    })
  })

  // More locales
  for (const lang of moreLocales) {
    const langTags = await getAllCombinedTags(lang)
    langTags.forEach((tag: string) => {
      paths.push({
        params: { tags_tag: `${lang}/tags/${tag}/` },
        props: { tag, lang },
      })
    })
  }

  return paths
}

const { tag, lang } = Astro.props
const { posts, projects } = await getContentByTag(tag, lang)
const supportedLangs = await getCombinedTagSupportedLangs(tag)

// Get categorized tags for the header
const [allPosts, allProjects] = await Promise.all([
  getPosts(lang),
  getProjects(lang),
])

const topicTags = [...new Set([
  ...allPosts.flatMap(post => post.data.tags?.topics || []),
  ...allProjects.flatMap(project => project.data.tags?.topics || []),
])].sort()

const projectTags = [...new Set([
  ...allPosts.flatMap(post => post.data.tags?.projects || []),
  ...allProjects.flatMap(project => project.data.tags?.projects || []),
])].sort()

const typeTags = [...new Set([
  ...allPosts.flatMap(post => post.data.tags?.types || []),
  ...allProjects.flatMap(project => project.data.tags?.types || []),
])].sort()
---

<Layout supportedLangs={supportedLangs}>
  <!-- First Bar: Topics & Projects -->
  <div class="uno-decorative-line" />
  <div class="grid grid-cols-1 mb-8 gap-8 md:grid-cols-2">
    <!-- Topics -->
    <div>
      <h2 class="mb-4 text-xl text-gray-700 font-semibold dark:text-gray-300">Topics</h2>
      {topicTags.length > 0
? (
        <TagList tags={topicTags} currentTag={tag} lang={lang} />
      )
: (
        <p class="text-gray-500 italic">No topics yet</p>
      )}
    </div>

    <!-- Projects -->
    <div>
      <h2 class="mb-4 text-xl text-gray-700 font-semibold dark:text-gray-300">Projects</h2>
      {projectTags.length > 0
? (
        <TagList tags={projectTags} currentTag={tag} lang={lang} />
      )
: (
        <p class="text-gray-500 italic">No projects yet</p>
      )}
    </div>
  </div>

  <!-- Second Bar: Content Types -->
  <div class="uno-decorative-line" />
  <div class="mb-8">
    <h2 class="mb-4 text-xl text-gray-700 font-semibold dark:text-gray-300">Content Types</h2>
    {typeTags.length > 0
? (
      <TagList tags={typeTags} currentTag={tag} lang={lang} />
    )
: (
      <p class="text-gray-500 italic">No content types yet</p>
    )}
  </div>

  <!-- Combined Content List -->
  <div class="mt-10.5">
    <CombinedContentList
      posts={posts}
      projects={projects}
      lang={lang}
    />
  </div>
</Layout>
